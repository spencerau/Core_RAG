# Copy to .env and fill in your values.
# Read by both docker compose (to configure the PostgreSQL container)
# and the Python code (db.py overrides config.yaml with these env vars).
# Priority: env vars > configs/config.local.yaml > configs/config.yaml

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=core_rag
